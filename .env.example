# AI Provider: gemini (recommended), groq, or ollama
AI_PROVIDER=gemini

# Gemini (free: 15 RPM, 1M tokens/day)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Groq (free: 30 RPM, 14.4K req/day for llama-3.1-8b-instant)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Ollama (local or remote instance)
OLLAMA_API=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b

# MongoDB Atlas
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?appName=SYNAPSE
MONGO_DB=synapse_db
